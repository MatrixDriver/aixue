# 数据库连接（Railway 会自动注入 DATABASE_URL）
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/aixue

# LLM API 密钥
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# LLM 模型选择
LLM_MODEL=claude-sonnet-4-6-20250514
LLM_MODEL_LIGHT=claude-haiku-4-5-20251001

# JWT 认证
SECRET_KEY=your-random-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# SymPy 验证
MAX_RETRY_COUNT=3
SYMPY_TIMEOUT=10

# 文件上传
UPLOAD_DIR=/app/uploads
MAX_IMAGE_SIZE=5242880
